# Copy this file to .env and fill in your Supabase project values.
# Find these in Supabase Dashboard > Project Settings > API.
#
# IMPORTANT: only the "anon public" key belongs here. Never put the
# "service_role" key in a .env file that ships to the browser — it
# bypasses Row Level Security entirely.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Stage 3 — not yet used by the app. Reserved for the Razorpay integration.
# This is the PUBLIC Key ID only (safe to expose) — get it from your
# company once their Razorpay merchant account is set up.
# The Key SECRET must never go here or anywhere VITE_-prefixed; it belongs
# in Supabase Edge Function secrets only. See README section 9.
VITE_RAZORPAY_KEY_ID=
